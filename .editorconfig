root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,html,css,scss,json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{java,kt,gradle,groovy,xml}]
indent_style = space
indent_size = 4

[*.ps1]
end_of_line = crlf
indent_style = space
indent_size = 2
